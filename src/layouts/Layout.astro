---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sistem Pendukung Keputusan berbasis SAW — Data bicara. Kamu putuskan.' } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Putuskan.id</title>
    <link rel="icon" type="image/png" href="/putuskan-logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
