---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';

const user = Astro.locals.user;
if (user) return Astro.redirect('/dashboard');
---

<Layout title="Beranda">
  <div class="min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-1">
      <!-- Hero -->
      <section class="border-b-2 border-[#1A1A1A] bg-white">
        <div class="container mx-auto px-4 max-w-6xl py-16 md:py-32">
          <div class="max-w-3xl">
            <div class="inline-block border-2 border-[#1A1A1A] bg-[#FF3D00] px-3 py-1 text-white text-xs md:text-sm font-bold mb-6">
              SISTEM PENDUKUNG KEPUTUSAN
            </div>
            <h1 class="text-4xl md:text-7xl font-bold text-[#1A1A1A] leading-tight mb-6">
              Data bicara.<br />
              <span class="text-[#FF3D00]">Kamu putuskan.</span>
            </h1>
            <p class="text-base md:text-lg text-[#333333] mb-8 md:mb-10 max-w-xl">
              Bingung milih antara banyak pilihan? Masukin faktor-faktornya, kasih nilai, dan biar sistem yang rangking.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/register" class="brutal-btn px-6 md:px-8 py-3 md:py-4 bg-[#FF3D00] text-white text-sm md:text-base font-bold inline-block">
                Mulai Gratis
              </a>
              <a href="#cara-kerja" class="brutal-btn px-6 md:px-8 py-3 md:py-4 bg-white text-[#1A1A1A] text-sm md:text-base font-bold inline-block">
                Cara Kerja
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Cara Kerja -->
      <section id="cara-kerja" class="py-20 border-b-2 border-[#1A1A1A]">
        <div class="container mx-auto px-4 max-w-6xl">
          <h2 class="text-3xl md:text-4xl font-bold mb-12">Cara kerjanya simpel<span class="text-[#FF3D00]">.</span></h2>
          <div class="grid md:grid-cols-3">
            {[
              { step: '01', title: 'Tentuin faktornya', desc: 'Apa aja yang penting buat kamu? Harga? Jarak? Rating? Tulis semua dan kasih tau seberapa penting masing-masing.' },
              { step: '02', title: 'Masukin pilihannya', desc: 'Daftarin semua opsi yang lagi kamu bandingin, terus beri nilai untuk setiap faktor.' },
              { step: '03', title: 'Lihat hasilnya', desc: 'Sistem langsung hitung dan kasih ranking. Ada detail perhitungannya juga kalau kamu mau lihat.' },
            ].map((item, i) => (
              <div class:list={['p-8 border-2 border-[#1A1A1A] bg-white', i > 0 ? 'md:-ml-[2px] -mt-[2px] md:mt-0' : '']}>
                <div class="text-5xl font-bold text-[#FF3D00] mb-4">{item.step}</div>
                <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                <p class="text-[#333333]">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-20 bg-[#1A1A1A]">
        <div class="container mx-auto px-4 max-w-6xl text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Udah bingung lama<span class="text-[#FF3D00]">?</span><br/>Yuk mulai sekarang.
          </h2>
          <a href="/register" class="brutal-btn px-8 py-4 bg-[#FF3D00] text-white text-base font-bold inline-block">
            Daftar Gratis
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t-2 border-[#1A1A1A] bg-white py-6">
      <div class="container mx-auto px-4 max-w-6xl flex justify-between items-center text-sm text-[#333333]">
        <img src="/putuskan-logo.png" alt="Putuskan.id" class="h-6 w-auto" />
        <span>© 2026</span>
      </div>
    </footer>
  </div>
</Layout>
